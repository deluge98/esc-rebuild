heckbox gfield--type-choice gfield--width-full field_sublabel_below gfield--no-description field_description_below field_validation_below gfield_visibility_visible\"  ><legend class='gfield_label gform-field-label gfield_label_before_complex' >I am not playing squash right now because&#8230;</legend><div class='ginput_container ginput_container_checkbox'><div class='gfield_checkbox ' id='input_89_3'><div class='gchoice gchoice_89_3_1'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_3.1' type='checkbox'  value='I am concerned about COVID'  id='choice_89_3_1'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_3_1' id='label_89_3_1' class='gform-field-label gform-field-label--type-inline'>I am concerned about COVID</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_3_2'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_3.2' type='checkbox'  value='I would like to play, but the people I normally play with are not playing currently'  id='choice_89_3_2'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_3_2' id='label_89_3_2' class='gform-field-label gform-field-label--type-inline'>I would like to play, but the people I normally play with are not playing currently</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_3_3'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_3.3' type='checkbox'  value='My schedule is making it inconvenient to play at the ESC at the moment'  id='choice_89_3_3'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_3_3' id='label_89_3_3' class='gform-field-label gform-field-label--type-inline'>My schedule is making it inconvenient to play at the ESC at the moment</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_3_4'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_3.4' type='checkbox'  value='Other'  id='choice_89_3_4'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_3_4' id='label_89_3_4' class='gform-field-label gform-field-label--type-inline'>Other</label>\n\t\t\t\t\t\t\t</div></div></div></fieldset><fieldset id=\"field_89_9\" class=\"gfield gfield--type-checkbox gfield--type-choice gfield--width-full field_sublabel_below gfield--no-description field_description_below field_validation_below gfield_visibility_visible\"  ><legend class='gfield_label gform-field-label gfield_label_before_complex' >On average, my attendance at the club since July 1, 2021 has been</legend><div class='ginput_container ginput_container_checkbox'><div class='gfield_checkbox ' id='input_89_9'><div class='gchoice gchoice_89_9_1'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_9.1' type='checkbox'  value='hardly at all'  id='choice_89_9_1'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_9_1' id='label_89_9_1' class='gform-field-label gform-field-label--type-inline'>hardly at all</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_9_2'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_9.2' type='checkbox'  value='less than once a week'  id='choice_89_9_2'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_9_2' id='label_89_9_2' class='gform-field-label gform-field-label--type-inline'>less than once a week</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_9_3'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_9.3' type='checkbox'  value='once a week'  id='choice_89_9_3'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_9_3' id='label_89_9_3' class='gform-field-label gform-field-label--type-inline'>once a week</label>\n\t\t\t\t\t\t\t</div><div class='gchoice gchoice_89_9_4'>\n\t\t\t\t\t\t\t\t<input class='gfield-choice-input' name='input_9.4' type='checkbox'  value='more than once a week'  id='choice_89_9_4'   />\n\t\t\t\t\t\t\t\t<label for='choice_89_9_4' id='label_89_9_4' class='gform-field-label gform-field-label--type-inline'>more than once a week</label>\n\t\t\t\t\t\t\t</div></div></div></fieldset><div id=\"field_89_1\" class=\"gfield gfield--type-survey gfield--input-type-likert field_sublabel_below gfield--no-description field_description_below field_validation_below gfield_visibility_visible gsurvey-survey-field \"  data-field-class=\"gsurvey-survey-field\" ><label class='gfield_label gform-field-label' >Are you concerned with the vaccine status of opponents you may face on the court?</label><div class='ginput_container ginput_container_likert'><table aria-label='Are you concerned with the vaccine status of opponents you may face on the court?' class='gsurvey-likert' id='input_89_1'><thead><tr><th id='likert_col_1_89_1' scope='col' role='presentation' class='gsurvey-likert-choice-label'>Very concerned – I cannot play with unvaccinated opponents</th><th id='likert_col_2_89_1' scope='col' role='presentation' class='gsurvey-likert-choice-label'>Very concerned – I want to know the vaccine status of an opponent to make a decision to play</th><th id='likert_col_3_89_1' scope='col' role='presentation' class='gsurvey-likert-choice-label'>Somewhat concerned</th><th id='likert_col_4_89_1' scope='col' role='presentation' class='gsurvey-likert-choice-label'>Not concerned</th></tr></thead><tbody><tr><td data-label='Very concerned – I cannot play with unvaccinated opponents' class='gsurvey-likert-choice'><input name='input_1' type='radio' value='glikertcol124cca797'  id='choice_89_1_1'    aria-labelledby='likert_col_1_89_1'/></td><td data-label='Very concerned – I want to know the vaccine status of an opponent to make a decision to play' class='gsurvey-likert-choice'><input name='input_1' type='radio' value='glikertcol1eae9b9b7'  id='choice_89_1_2'    aria-labelledby='likert_col_2_89_1'/></td><td data-label='Somewhat concerned' class='gsurvey-likert-choice'><input name='input_1' type='radio' value='glikertcol1511abd92'  id='choice_89_1_3'    aria-labelledby='likert_col_3_89_1'/></td><td data-label='Not concerned' class='gsurvey-likert-choice'><input name='input_1' type='radio' value='glikertcol1c04bb9ef'  id='choice_89_1_4'    aria-labelledby='likert_col_4_89_1'/></td></tr></tbody></table></di